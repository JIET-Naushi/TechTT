# Environment Variables Template
# Copy this file to .env and fill in your values

# PostgreSQL connection (Neon DB)
# Get from: https://console.neon.tech
POSTGRES_URL=your_postgres_connection_string_here

# JWT secret for signing tokens (generate a strong random string)
# Example: openssl rand -base64 32
JWT_SECRET=your_jwt_secret_here

# Google OAuth Client ID (get from Google Cloud Console)
# https://console.cloud.google.com/apis/credentials
# Create OAuth 2.0 Client ID and add authorized origins
GOOGLE_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com

# Gmail credentials for sending password reset emails
# Use a Gmail App Password (not your regular password):
# Google Account → Security → 2-Step Verification → App passwords
# Create an app password and paste it below.
MAIL_USER=your_gmail_address@gmail.com
MAIL_PASS=your_16_char_app_password

# App base URL (used in reset email links)
# For Vercel: leave blank — VERCEL_URL is set automatically
# For local: http://localhost:3000
APP_URL=

# Node environment
NODE_ENV=production
